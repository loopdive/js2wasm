{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": ["Bash(*)"]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | head -c 140 | xargs -0 -I{} curl -H 'Title: ts2wasm' -d '{}' http://host.docker.internal:8090/loopdive-claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git checkout*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-cwd.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git add*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-git-commit.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-git-commit.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(npm test*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-test.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(pnpm run test*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-test.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(npx vitest*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-test.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(node*vitest*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-test.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git merge*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-merge.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-shutdown.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-agent-spawn.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(npm test*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-test.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(pnpm run test*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-test.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(npx vitest*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-test.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
