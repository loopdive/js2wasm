{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true"
  },
  "permissions": {
    "allow": ["Bash(*)"],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /workspace*)",
      "Bash(rm /workspace*)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(> /etc/*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)"
    ]
  }
}
